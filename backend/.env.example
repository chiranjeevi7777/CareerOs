# Job Hunt OS AI Backend — Environment Variables
# Copy this file to .env and fill in your actual API keys.

# ── LLM Provider Keys ──
# The backend auto-detects which provider to use based on available keys.
# Priority: GEMINI → OPENAI → ANTHROPIC → GROQ → Mock (no keys)

GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ── Optional: Force a specific provider and model ──
# Set LLM_PROVIDER to one of: gemini, openai, anthropic, groq
# If not set, the backend will auto-detect from the keys above.
LLM_PROVIDER=
MODEL_NAME=

# ── Server Settings ──
HOST=127.0.0.1
PORT=8000
